# Force LF line endings for everything checked into the repo. Without this,
# Windows clients with core.autocrlf=true can poison shell scripts and the
# Dockerfile with CRLF, which then fails inside Linux containers
# ("/usr/bin/env: 'bash\r': No such file or directory").

* text=auto eol=lf

# Shell scripts and Docker artefacts MUST be LF.
*.sh           text eol=lf
Dockerfile     text eol=lf
*.dockerfile   text eol=lf
docker-compose*.yml text eol=lf
docker-entrypoint.sh text eol=lf

# Don't touch binaries.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
